# =============================================
# Register Service 環境變數範本
# 複製為 .env 並依需求調整。請勿把含真實憑證的 .env commit 進版控。
# =============================================

NODE_ENV=development
PORT=3008

# PostgreSQL 連線字串
# 生產環境（EC2）請改成實際的 RDS 位址（建議透過 PgBouncer 連線池）
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/register_db"

# ---- AWS 設定 ----
AWS_REGION=ap-northeast-1

# 私有 S3 Bucket 名稱（存放營登 PDF）。生產環境必填。
AWS_S3_BUCKET_NAME=register-documents-private-01

# 本地開發 AWS 憑證（生產環境用 EC2 Instance Profile，不需要設這兩項）
# 若你的 ~/.aws/credentials 已設定 profile，本地也可以不填
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- 跨服務 HTTP 整合 ----
# 核准入駐時，register-service 直接呼叫以下兩個服務建立帳號與商家記錄

# IAM Service URL（建立商家帳號）
IAM_SERVICE_URL=http://localhost:3001

# Vendor & Menu Service URL（建立商家記錄）
VENDOR_MENU_SERVICE_URL=http://localhost:3007

# 內部 Admin 帳號（向 IAM 取得 admin JWT 用，需與 IAM 的 seed.sql admin 帳號一致）
INTERNAL_ADMIN_EMAIL=admin1@test.com
INTERNAL_ADMIN_PASSWORD=admin123

# ---- SMTP（歡迎信，選填）----
# 未設定 SMTP_HOST 時歡迎信只寫入 log，不影響核准流程（方便本地開發）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_16_char_app_password
# EMAIL_FROM=your_email@gmail.com
