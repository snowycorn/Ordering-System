{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Ordering System Overview",
  "uid": "ordering-overview",
  "tags": ["ordering-system"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "expr": "up{job=~\"$job\"}", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate (QPS) by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_total{job=~\"$job\"}[1m]))", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "5xx Error Rate by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_total{job=~\"$job\", status_code=~\"5..\"}[5m]))", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Latency p95 by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])))", "legendFormat": "{{job}} p95", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Latency p50 / p99 (all selected)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])))", "legendFormat": "p99", "refId": "B" }
      ]
    },
    {
      "id": 6,
      "title": "Process Resident Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=~\"$job\"}", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes{job=~\"$job\"}", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "title": "Logs — all services",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "expr": "{service_name=~\"vendor-menu-service|register-service|iam|notification|recommendation|billing|appeal-admin|order-service\"}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "title": "Error Logs — all services",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "expr": "{service_name=~\"vendor-menu-service|register-service|iam|notification|recommendation|billing|appeal-admin|order-service\"} |~ `(?i)\"level\":\\s*\"?(error|fatal)\"?|\"level\":\\s*(50|60)|\"levelname\":\\s*\"(error|critical)\"`", "refId": "A" }
      ]
    }
  ]
}
