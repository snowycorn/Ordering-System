// vendor-menu-service/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Vendor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       Int?     @unique @map("user_id")  // IAM 數字 userId，供 /me* 自管路由解析
  name         String   @db.VarChar(255)
  category     String?  @db.VarChar(100)        // 商家類別（中式、日式、便當...）
  description  String?  @db.Text                 // 商家描述
  factoryZones String[] @default([]) @map("factory_zones") // 服務廠區（可多個），詞彙範圍見 factory-zones.constant.ts
  violationPoints Int   @default(0) @map("violation_points") // 違規點數，管理員累加
  status       String   @default("ACTIVE") @db.VarChar(50)
  suspendedAt   DateTime? @map("suspended_at") @db.Timestamptz   // 停權時間（復權時清空）
  suspendedBy   Int?      @map("suspended_by")                   // 停權 admin 的 IAM userId
  suspendReason String?   @map("suspend_reason") @db.Text        // 停權原因（必填於 API 層）
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  menus        Menu[]

  @@map("vendors")
}

model Menu {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId    String   @map("vendor_id") @db.Uuid
  name        String   @db.VarChar(255)
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?  @map("image_url") @db.Text
  dailyLimit  Int      @default(0) @map("daily_limit") // 預設每日限量（0 表示當日無庫存，需設 quota 開量）
  tags        String[] @default([]) @map("tags") // 菜單標籤（英文 code，可複選），詞彙範圍見 menu-tags.constant.ts
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  vendor      Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  dailyQuotas DailyQuota[]

  @@map("menus")
  @@index([vendorId])
}

// 每日限量覆蓋表（override dailyLimit from targetDate onward）
// 一筆 quota 的 targetDate=T 代表「從 T 當天起、之後所有日期」皆套用此 maxQuantity，
// 直到出現另一筆 targetDate 更晚的 quota 才被接續覆蓋。
model DailyQuota {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId      String   @map("menu_id") @db.Uuid
  targetDate  DateTime @map("target_date") @db.Date
  maxQuantity Int      @map("max_quantity")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  menu        Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("daily_quotas")
  @@unique([menuId, targetDate])
  @@index([menuId, targetDate])
}
