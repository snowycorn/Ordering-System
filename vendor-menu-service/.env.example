# =============================================
# 環境變數範本：複製成 .env 後依本機需求調整
#   cp .env.example .env
# .env 不要 commit；生產環境請透過 K8s Secret / 環境變數注入
# =============================================

NODE_ENV=development
PORT=3007

# PostgreSQL 連線字串（必填）
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vendor_menu_db"

# ---- AWS 設定 ----
# 憑證一律由 SDK 自動取得（本機 ~/.aws/credentials profile，生產環境 IRSA / Instance Profile），
# 不需在此設定 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY。
AWS_REGION=ap-northeast-1

# S3 Bucket 名稱（開發選填，生產必填）
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# CloudFront Domain（選填）：設定後 imageUrl 走 CDN，否則走 S3 直連
# AWS_CLOUDFRONT_DOMAIN=d1234abcd.cloudfront.net

# ---- Order-Inventory 服務（必填）----
# 建立菜單與每日 cron 用來推送每日庫存；範例：http://<host>:8081
# 本地若未啟動 order-inventory，推送會 best-effort 失敗只記 log，不影響菜單建立
ORDER_INVENTORY_SERVICE_URL=http://localhost:8081

# 直連 order-inventory 時帶的 X-User-Id（選填，預設 0；role 固定送 admin）
# INTERNAL_ADMIN_USER_ID=0
